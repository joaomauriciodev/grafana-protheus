  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["protheus", "loki", "logs"],
  "templating": {
    "list": [
      {
        "current": {},
        "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
        "definition": "label_values(rotina)",
        "hide": 0,
        "includeAll": true,
        "label": "Rotina",
        "multi": true,
        "name": "rotina",
        "options": [],
        "query": "label_values(rotina)",
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "type": "query",
        "allValue": ".*"
      },
      {
        "current": { "selected": false, "text": "", "value": "" },
        "hide": 0,
        "label": "Busca",
        "name": "busca",
        "options": [{ "selected": true, "text": "", "value": "" }],
        "query": "",
        "skipUrlSync": false,
        "type": "textbox"
      }
    ]
