{
  "title": "Protheus - Logs",
  "uid": "protheus-simples",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "browser",
  "tags": ["protheus"],
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total de logs",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "loki", "uid": "loki-uid" },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "loki", "uid": "loki-uid" },
        "expr": "sum(count_over_time({job=\"protheus\"}[$__range]))"
      }],
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] } } }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "ERRORs",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "loki", "uid": "loki-uid" },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "loki", "uid": "loki-uid" },
        "expr": "sum(count_over_time({job=\"protheus\"} |= \"[ERROR]\" [$__range]))"
      }],
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } } }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "WARNs",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "loki", "uid": "loki-uid" },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "loki", "uid": "loki-uid" },
        "expr": "sum(count_over_time({job=\"protheus\"} |= \"[WARN ]\" [$__range]))"
      }],
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }] } } }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "INFOs",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "loki", "uid": "loki-uid" },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "loki", "uid": "loki-uid" },
        "expr": "sum(count_over_time({job=\"protheus\"} |= \"[INFO ]\" [$__range]))"
      }],
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] } } }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "DEBUGs",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "loki", "uid": "loki-uid" },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "loki", "uid": "loki-uid" },
        "expr": "sum(count_over_time({job=\"protheus\"} |= \"[DEBUG]\" [$__range]))"
      }],
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [{ "color": "purple", "value": null }] } } }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Volume por tipo ao longo do tempo",
      "gridPos": { "x": 0, "y": 4, "w": 24, "h": 8 },
      "datasource": { "type": "loki", "uid": "loki-uid" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki-uid" },
          "expr": "sum(count_over_time({job=\"protheus\"} |= \"[ERROR]\" [$__interval]))",
          "legendFormat": "ERROR"
        },
        {
          "refId": "B",
          "datasource": { "type": "loki", "uid": "loki-uid" },
          "expr": "sum(count_over_time({job=\"protheus\"} |= \"[WARN ]\" [$__interval]))",
          "legendFormat": "WARN"
        },
        {
          "refId": "C",
          "datasource": { "type": "loki", "uid": "loki-uid" },
          "expr": "sum(count_over_time({job=\"protheus\"} |= \"[INFO ]\" [$__interval]))",
          "legendFormat": "INFO"
        },
        {
          "refId": "D",
          "datasource": { "type": "loki", "uid": "loki-uid" },
          "expr": "sum(count_over_time({job=\"protheus\"} |= \"[DEBUG]\" [$__interval]))",
          "legendFormat": "DEBUG"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "bars", "fillOpacity": 80, "stacking": { "mode": "normal", "group": "A" } }
        }
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 7,
      "type": "logs",
      "title": "Todos os logs",
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 12 },
      "datasource": { "type": "loki", "uid": "loki-uid" },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "loki", "uid": "loki-uid" },
        "expr": "{job=\"protheus\"}"
      }],
      "options": {
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true,
        "enableLogDetails": true,
        "dedupStrategy": "none"
      }
    },
    {
      "id": 8,
      "type": "logs",
      "title": "Apenas ERRORs",
      "gridPos": { "x": 0, "y": 24, "w": 24, "h": 8 },
      "datasource": { "type": "loki", "uid": "loki-uid" },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "loki", "uid": "loki-uid" },
        "expr": "{job=\"protheus\"} |= \"[ERROR]\""
      }],
      "options": {
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true,
        "enableLogDetails": true
      }
    }
  ]
}
