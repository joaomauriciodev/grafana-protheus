      "type": "logs",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "{job=\"protheus\"} |= \"[ERROR]\"",
          "legendFormat": "",
          "refId": "A"
        }
      ]
