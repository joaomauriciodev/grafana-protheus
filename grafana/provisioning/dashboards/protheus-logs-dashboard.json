        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "sum(count_over_time({job=\"protheus\"} |= \"[WARN ]\" [$__range]))",
          "legendFormat": "WARN",
          "refId": "B"
